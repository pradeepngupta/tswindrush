{
  "name": "tswindrush",
  "homepage": "https://tsw-ind-rush.vercel.app/",
  "author": "Pradeep Gupta <pradeepngupta@gmail.com>",
  "version": "1.0.0",
  "private": true,
  "description": "A Next.js project template with TypeScript and Tailwind CSS for rapid development.",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepngupta/tswindrush.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "tsc": "npx tsc --noEmit",
    "lint": "eslint --fix .",
    "format": "prettier --check . --config ./.prettierrc",
    "format:fix": "prettier --write . --config ./.prettierrc",
    "prepare": "husky",
    "pretest": "npm run lint && tsc --noEmit",
    "posttest": "npm run format",
    "test:jest": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test": "npm run test:jest --",
    "test:e2e": "npx playwright test",
    "test:e2e-ui": "npx playwright test --ui",
    "test:e2e-debug": "npx playwright test --debug"
  },
  "dependencies": {
    "@next/eslint-plugin-next": "16.2.10",
    "next": "16.2.10",
    "npm": "11.18.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.6",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@swc/jest": "0.2.39",
    "@tailwindcss/postcss": "4.3.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "30.0.0",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@typescript-eslint/eslint-plugin": "8.65.0",
    "@typescript-eslint/parser": "8.65.0",
    "autoprefixer": "10.5.4",
    "eslint": "10.7.0",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "lint-staged": "17.0.8",
    "postcss": "8.5.19",
    "prettier": "3.9.5",
    "tailwindcss": "4.3.3",
    "tailwindcss-animate": "1.0.7",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "7.0.2"
  },
  "overrides": {
    "picomatch": "4.0.4"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
